# FLYWEEL AGENTIC CONTENT ENGINE - Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================
# REQUIRED API KEYS
# ============================================

# Gemini (Google AI) - For content generation
# Get your key at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Groq - For fast inference and community mining
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Perplexity - For SERP analysis and web research
# Get your key at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ============================================
# OPTIONAL API KEYS
# ============================================

# Nebius or any OpenAI-compatible API - For content polishing
# E.g. https://api.openai.com/v1, https://api.together.xyz/v1, etc.
# Default base is Nebius Studio (https://api.studio.nebius.ai/v1/)
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=your_openai_compatible_api_key_here

# Google Search Console (optional) - For keyword research
# Path to your service account JSON file
GOOGLE_SERVICE_ACCOUNT_PATH=/path/to/service-account.json
GSC_SITE_URL=https://yourdomain.com

# ============================================
# CONFIGURATION
# ============================================

# Author email (for frontmatter)
AUTHOR_EMAIL=hello@yourdomain.com

# ============================================
# NOTES
# ============================================
# - Never commit the .env file to git
# - Keep your API keys secure
# - For CI/CD, add these as repository secrets
# - Missing optional keys will skip those features gracefully
